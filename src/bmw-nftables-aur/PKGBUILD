# Maintainer: borismw <52957119+borismw@users.noreply.github.com>
pkgname=bmw-nftables
pkgver=0.1.0
pkgrel=1
pkgdesc='Modular firewall ruleset on top of nftables'
arch=('any')
url='https://github.com/borismw/bmw-nftables/tree/main'
license=('MIT')
depends=('nftables' 'networkmanager')
backup=('etc/nftables.conf')
options=('!debug')
install='bmw-nftables-rules.install'
source=("https://github.com/borismw/bmw-nftables/releases/download/v${pkgver}/${pkgname}-v${pkgver}-sources.tar.gz" "https://github.com/borismw/bmw-nftables/releases/download/v${pkgver}/${pkgname}-v${pkgver}-sources.tar.gz.sig")
validpgpkeys=("FAFBEC9638D5B553EE404868A6856139D938A2B5")
sha256sums=("6b0b140dc13fda30d0e939adcdd5ad822b45eea65888fb81c7dc2508a8627ed7" "ca7606e10776f5d10c124aa3e021b21f439aa86f1727566f40ed59b5dcf43013")

pkgver() {
    echo "$pkgver"
}

package() {
    install -Dm 644 "$srcdir/etc/nftables-main.rules" "$pkgdir/etc/nftables-main.rules"
    for file in "$srcdir"/etc/nftables/*.rules; do
        install -Dm 644 "$file" "$pkgdir/etc/nftables/${file##*/}"
    done
}
